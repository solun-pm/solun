{
  "name": "@solun/api",
  "version": "1.3.10",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @solun/shared build",
    "dev": "tsx watch src/index.ts",
    "prestart": "pnpm --filter @solun/shared build",
    "prebuild": "prisma generate --schema=prisma/schema.prisma",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "cleanup": "tsx src/run-file-cleanup.ts",
    "lint": "echo \"No lint configured\"",
    "pretypecheck": "prisma generate --schema=prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@solun/shared": "workspace:*",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.0.0",
    "nanoid": "^5.1.11",
    "node-cron": "^4.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
